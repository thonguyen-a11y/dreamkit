# Leave unset in local dev to use the Next.js proxy (avoids CORS).
# NEXT_PUBLIC_API_URL=

# Backend origin used by the dev proxy rewrite (server-side only).
API_PROXY_URL=http://localhost:8000

# Production: set to your API origin with CORS allowed for the frontend host.
# NEXT_PUBLIC_API_URL=https://api.dreamkit.vn

# Optional: override where product image paths are resolved.
# NEXT_PUBLIC_UPLOADS_URL=https://dreamkit.vn/wp-content
